{
  "openapi": "3.0.0",
  "paths": {
    "/media/upload": {
      "post": {
        "operationId": "CloudinaryController_uploadImage",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CloudinaryResponseDto"
                }
              }
            }
          }
        },
        "summary": "Upload ảnh từ máy tính lên Cloudinary",
        "tags": [
          "Media - Cloudinary"
        ]
      }
    }
  },
  "info": {
    "title": "Cloudinary Media Service",
    "description": "Tài liệu API hệ thống lưu trữ ảnh Wardrobe",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "schemas": {
      "CloudinaryResponseDto": {
        "type": "object",
        "properties": {
          "public_id": {
            "type": "string",
            "example": "wardrobe_app/shoes_v1",
            "description": "ID định danh trên Cloudinary"
          },
          "url": {
            "type": "string",
            "example": "https://res.cloudinary.com/.../image.jpg",
            "description": "URL ảnh gốc"
          },
          "optimizedUrl": {
            "type": "string",
            "example": "https://res.cloudinary.com/.../f_auto,q_auto/image.jpg",
            "description": "URL đã tối ưu"
          }
        },
        "required": [
          "public_id",
          "url",
          "optimizedUrl"
        ]
      }
    }
  }
}